{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "aes-js": "^3.1.2",
    "expo": "~56.0.12",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-get-random-values": "~1.11.0"
  },
  "devDependencies": {
    "@types/aes-js": "^3.1.4",
    "@types/react": "~19.2.2",
    "dotenv-cli": "^7.4.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:staging": "dotenv -e .env.staging -- expo start",
    "start:production": "dotenv -e .env.production -- expo start",
    "android:staging": "dotenv -e .env.staging -- expo start --android",
    "android:production": "dotenv -e .env.production -- expo start --android",
    "ios:staging": "dotenv -e .env.staging -- expo start --ios",
    "ios:production": "dotenv -e .env.production -- expo start --ios",
    "web:staging": "dotenv -e .env.staging -- expo start --web",
    "web:production": "dotenv -e .env.production -- expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
