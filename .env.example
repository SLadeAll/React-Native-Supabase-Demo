# Used by `vercel dev` (api/config.ts) and `supabase` CLI commands.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
VERCEL_PROJECT_NAME=react-native-supabase-project

# Echoed back by /api/config so the client can confirm which backend
# environment answered. Set to "staging" or "production" when running
# `vercel dev` / deploying — see mobile/README.md for the client-side half
# of this toggle.
APP_ENV=staging
